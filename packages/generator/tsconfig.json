{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["esnext"],
    "strict": true,
    "strictPropertyInitialization": false,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": true,
    "sourceMap": true,
    "declaration": true,
    "baseUrl": ".",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    "newLine": "lf"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "**/node_modules",
    "**/*.test.ts",
    "**/__tests__",
    "**/dest",
    "src/copy/**/*.ts",
    "src/openapi/**/*.ts"
  ]
}
